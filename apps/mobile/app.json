{
  "expo": {
    "name": "GrandTour",
    "slug": "grandtour",
    "scheme": "grandtour",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "app.tipping",
      "buildNumber": "2",
      "infoPlist": {
        "CFBundleDisplayName": "GrandTour Tips"
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.tippingsuite.f1tips",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
